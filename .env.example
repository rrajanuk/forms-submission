# Server Configuration
NODE_ENV=development
PORT=4000
HOST=127.0.0.1

# Database (REQUIRED - SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./data/forms.db"

# JWT Secrets (REQUIRED - generate with: openssl rand -base64 64)
JWT_SECRET=your-jwt-secret-min-64-chars-change-in-production
REFRESH_TOKEN_SECRET=your-refresh-token-secret-min-64-chars-change-in-production

# CORS (comma-separated list of allowed origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080

# Email Notifications (SMTP)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
NOTIFICATION_EMAIL=admin@example.com

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=5
RATE_LIMIT_WINDOW_MS=3600000
